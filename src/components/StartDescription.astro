---
import { Image } from 'astro:assets';

import Container from '@/components/Container.astro';
import Badge from '@/components/Badge.astro';
import IconPill from '@/components/IconPill.astro';
import GitHubIcon from '@/assets/icons/GitHubIcon.svg';
import LinkedinIcon from '@/assets/icons/LinkedinIcon.svg';
import GmailIcon from '@/assets/icons/GmailIcon.svg';
import profileImg from '@/assets/images/perfil-linkedin.webp';
---

<section id="start" class="sm:mbs-16 py-10 sm:py-20">
  <Container>
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:gap-0">
      <div class="space-y-6 sm:w-[65%]">
        <Badge>Frontend / Full Stack</Badge>
        <h1 class="typing-title text-4xl font-black md:text-6xl">
          Sergio Jiménez
        </h1>
        <p class="text-pretty text-xl lg:text-2xl">
          Desarrollador web con más de 5 años de experiencia creando
          aplicaciones, herramientas propias e interfaces centradas en
          usabilidad. Trabajo desde Albacete con foco en frontend, perfil
          full-stack, docencia técnica e IA aplicada al flujo de desarrollo.
        </p>
        <nav class="text-muted flex flex-wrap gap-3">
          <IconPill
            href="https://www.linkedin.com/in/sergio-jim%C3%A9nez-rubio/"
            brand="Linkedin"
            label="Abrir perfil de Linkedin de Sergio Jiménez"
          >
            <LinkedinIcon
              class="size-5 transition-transform duration-300 group-hover:scale-110"
              aria-hidden="true"
            />
            Linkedin
          </IconPill>
          <IconPill
            href="https://github.com/sergio-jr-dev"
            brand="GitHub"
            label="Abrir perfil de GitHub de Sergio Jiménez"
          >
            <GitHubIcon
              class="size-5 transition-transform duration-300 group-hover:scale-110"
              aria-hidden="true"
            />
            GitHub
          </IconPill>
          <IconPill
            href="mailto:sergiojimenezrubio.dev@gmail.com"
            brand="Gmail"
            label="Enviar email a Sergio Jiménez"
          >
            <GmailIcon
              class="size-5 transition-transform duration-300 group-hover:scale-110"
              aria-hidden="true"
            />
            sergiojimenezrubio.dev@gmail.com
          </IconPill>
        </nav>
      </div>
      <div class="flex justify-center sm:w-[35%] sm:justify-end">
        <Image
          src={profileImg}
          alt="Sergio Jiménez Rubio"
          loading="eager"
          class="animate-blurred-fade-in mask-[linear-gradient(to_bottom,#000_85%,transparent_100%)] drop-shadow-primary/70 drop-shadow-xs h-auto w-[min(16rem,100%)] object-contain sm:w-full sm:max-w-64 md:max-w-72"
        />
      </div>
    </div>
  </Container>
</section>

<style>
  @supports (interpolate-size: allow-keywords) {
    .typing-title {
      interpolate-size: allow-keywords;
      display: inline-block;
      overflow-x: clip;
      white-space: nowrap;
      border-right: 2px solid currentColor;
      animation:
        start-title-typing 1s steps(14) 0.1s both,
        start-title-blink 0.8s step-end infinite;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typing-title {
      animation: none;
      border-right: 0;
    }
  }

  @keyframes start-title-typing {
    from {
      width: 0;
    }

    to {
      width: max-content;
    }
  }

  @keyframes start-title-blink {
    50% {
      border-color: transparent;
    }
  }
</style>
