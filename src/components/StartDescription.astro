---
import { Image } from 'astro:assets';

import Container from '@/components/Container.astro';
import Badge from '@/components/Badge.astro';
import IconPill from '@/components/IconPill.astro';
import GitHubIcon from '@/assets/icons/GitHubIcon.svg';
import LinkedinIcon from '@/assets/icons/LinkedinIcon.svg';
import GmailIcon from '@/assets/icons/GmailIcon.svg';
import profileImg from '@/assets/perfil-linkedin.webp';
---

<section id="start" class="sm:mbs-16 py-10 sm:py-20">
  <Container>
    <div class="flex flex-col gap-6 sm:flex-row sm:gap-0 md:items-center">
      <div class="sm:w-[65%]">
        <h1
          class="flex flex-wrap items-center gap-3 pb-6 text-4xl font-black lg:text-6xl"
        >
          Sergio Jiménez
          <Badge>Frontend / Full Stack</Badge>
        </h1>
        <h2 class="text-pretty text-xl leading-8 lg:text-2xl lg:leading-9">
          Desarrollador web con más de 5 años de experiencia creando
          aplicaciones, herramientas propias e interfaces centradas en
          usabilidad. Trabajo desde Albacete combinando frontend, bases
          full-stack, docencia técnica e IA aplicada al flujo de desarrollo.
        </h2>
        <nav class="text-muted mt-6 flex flex-wrap gap-3">
          <IconPill
            href="https://www.linkedin.com/in/sergio-jim%C3%A9nez-rubio/"
            brand="Linkedin"
            label="Abrir perfil de Linkedin de Sergio Jiménez"
          >
            <LinkedinIcon class="size-5" aria-hidden="true" />
            Linkedin
          </IconPill>
          <IconPill
            href="https://github.com/sergio-jr-dev"
            brand="GitHub"
            label="Abrir perfil de GitHub de Sergio Jiménez"
          >
            <GitHubIcon class="size-5" aria-hidden="true" />
            GitHub
          </IconPill>
          <IconPill
            href="mailto:sergiojimenezrubio.dev@gmail.com"
            brand="Gmail"
            label="Enviar email a Sergio Jiménez"
          >
            <GmailIcon class="size-5" aria-hidden="true" />
            sergiojimenezrubio.dev@gmail.com
          </IconPill>
        </nav>
      </div>
      <div class="sm:w-[35%]">
        <Image
          src={profileImg}
          alt="Sergio Jiménez Rubio"
          loading="eager"
          class="mask-[linear-gradient(to_bottom,#000_85%,transparent_100%)] drop-shadow-primary/70 drop-shadow-xs h-110 w-fit justify-self-center object-contain md:justify-self-end"
        />
      </div>
    </div>
  </Container>
</section>
