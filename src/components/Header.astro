---
import ThemeSelector from './ThemeSelector.astro';
import HeaderLink from './HeaderLink.astro';

const links = [
  { href: '#start', title: 'Inicio' },
  { href: '#about', title: 'Sobre Mí' },
  { href: '#experience', title: 'Experiencia' },
  { href: '#projects', title: 'Proyectos' },
];
---

<header class="fixed inset-x-0 top-3 z-20 mx-auto max-w-5xl px-3">
  <nav
    aria-label="Navegación principal"
    class="border-border bg-surface-elevated text-muted animate-nav-shadow mx-auto flex w-full max-w-max items-center rounded-full border p-0.5 shadow-sm shadow-black/5 backdrop-blur [animation-range:50px_150px] [animation-timeline:scroll()] motion-reduce:animate-none"
  >
    {links.map((link) => <HeaderLink {...link} />)}
    <ThemeSelector />
  </nav>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const sections = document.querySelectorAll('main section[id]');
    const navLinks = document.querySelectorAll('header nav a[href^="#"]');

    if (!sections.length || !navLinks.length) return;

    const setActiveLink = (id) => {
      if (!id) return;

      navLinks.forEach((link) => {
        link.classList.remove('active');
        link.removeAttribute('aria-current');

        if (link.getAttribute('href') === `#${id}`) {
          link.classList.add('active');
          link.setAttribute('aria-current', 'page');
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActiveLink(entry.target.id);
        });
      },
      { rootMargin: '-35% 0px -55% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
    setActiveLink(sections[0].id);
  });
</script>
