---
import HomeIcon from '@/assets/icons/HomeIcon.svg';
import AppWindowIcon from '@/assets/icons/AppWindowIcon.svg';
import BriefCaseIcon from '@/assets/icons/BriefCaseIcon.svg';
import UserIcon from '@/assets/icons/UserIcon.svg';
import Container from './Container.astro';
import ThemeSelector from './ThemeSelector.astro';
import HeaderLink from './HeaderLink.astro';

const links = [
  {
    href: '#start',
    icon: HomeIcon,
    title: 'Inicio',
  },
  {
    href: '#projects',
    icon: AppWindowIcon,
    title: 'Proyectos',
  },
  {
    href: '#experience',
    icon: BriefCaseIcon,
    title: 'Experiencia',
  },
  {
    href: '#about',
    icon: UserIcon,
    title: 'Sobre mí',
  },
];
---

<header class="sm:inset-bs-3 inset-be-3 fixed inset-x-0 z-10 sm:sticky">
  <Container>
    <nav
      aria-label="Navegación principal"
      class="border-border text-muted sm:animate-nav-shadow bg-surface/75 backdrop-blur-xs shadow-sjr sm:timeline-scroll sm:animate-range-[entry_50px_150px] mx-auto flex items-center rounded-full border p-0.5 text-sm sm:max-w-max sm:text-base sm:motion-reduce:animate-none"
    >
      {links.map((link) => <HeaderLink {...link} />)}
      <ThemeSelector class="ms-0.5 hidden sm:flex" />
    </nav>
  </Container>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const sections = document.querySelectorAll('main section[id]');
    const navLinks = document.querySelectorAll('header nav a[href^="#"]');

    if (!sections.length || !navLinks.length) return;

    const setActiveLink = (id) => {
      if (!id) return;

      navLinks.forEach((link) => {
        link.classList.remove('active');
        link.removeAttribute('aria-current');

        if (link.getAttribute('href') === `#${id}`) {
          link.classList.add('active');
          link.setAttribute('aria-current', 'page');
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActiveLink(entry.target.id);
        });
      },
      { rootMargin: '-35% 0px -55% 0px', threshold: 0 }
    );

    sections.forEach((section) => observer.observe(section));
    setActiveLink(sections[0].id);
  });
</script>
