---
import ThemeSelector from "./ThemeSelector.astro";
---

<header class="fixed left-0 right-0 top-2 z-10 mx-auto max-w-5xl">
  <nav
    class="mx-auto flex max-w-max items-center justify-center gap-x-10 rounded-full bg-blue-100/90 px-5 py-2 text-slate-900 shadow-sm shadow-slate-500 dark:bg-blue-900/90 dark:text-slate-200 dark:shadow-blue-300"
  >
    <a href="#start">Inicio</a>
    <a href="#experience">Experiencia</a>
    <a href="#projects">Proyectos</a>
    <a href="#about">Sobre mí</a>
    <a href="mailto:sjr.social@gmail.com">Contacto</a>
    <ThemeSelector />
  </nav>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const sections = document.querySelectorAll("section");
    const navLinks = document.querySelectorAll("a");

    const updateActiveLink = () => {
      let currentSection = "";

      sections.forEach((section) => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;

        if (window.scrollY >= sectionTop - sectionHeight / 3) {
          currentSection = section.getAttribute("id");
        }
      });

      navLinks.forEach((link) => {
        link.classList.remove("active");
        if (link.getAttribute("href").includes(currentSection)) {
          link.classList.add("active");
        }
      });
    };

    window.addEventListener("scroll", updateActiveLink);
  });
</script>

<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 50px 150px;

    .active {
      @apply font-bold text-violet-700 dark:text-amber-500;
    }
  }

  @keyframes nav-shadown {
    from {
      @apply bg-transparent shadow-transparent;
    }
    to {
      @apply backdrop-blur-sm;
    }
  }
</style>
