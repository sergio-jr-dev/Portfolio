---
interface Props {
  title: string;
  company: string;
  description: string;
  date: string;
}

const { title, company, description, date } = Astro.props;
---

<div
  class="relative mx-12 pb-12 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 dark:before:border-white/15 before:content-[''] md:grid-cols-5 md:gap-10 md:space-x-4]"
>
  <div class="relative pb-12 md:col-span-2">
    <div class="sticky top-0">
      <span
        class="text-[#9aff00] dark:text-[#e7a702] -left-[42px] absolute rounded-full text-5xl"
        >&bull;</span
      >

      <h3 class="text-xl font-bold text-[#9aff00] dark:text-[#e7a702]">
        {title}
      </h3>
      <h4 class="font-semibold text-xl text-gray-950 dark:text-white">
        {company}
      </h4>
      <time class="p-0 m-0 text-sm text-gray-950/90 dark:text-white/90"
        >{date}</time
      >
    </div>
  </div>
  <div
    class="relative flex flex-col gap-2 pb-4 text-gray-950 dark:text-gray-100 md:col-span-3 text-pretty"
  >
    {description}
  </div>
</div>
