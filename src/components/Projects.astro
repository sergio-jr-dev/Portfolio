---
import { Image } from 'astro:assets';
import Container from '@/components/Container.astro';
import TechnologyPill from '@/components/TechnologyPill.astro';
import baselinelabImage from '@/assets/images/projects/baselinelab.webp';
import temariosImage from '@/assets/images/projects/temarios.webp';
import flipifriendsImage from '@/assets/images/projects/flipi-friends.webp';

const projects = [
  {
    title: 'BaselineLab',
    description:
      'Plataforma en desarrollo con playgrounds y generadores de CSS y HTML, orientada a acelerar pruebas visuales, creación de código y productividad frontend.',
    link: 'https://baselinelab.dev',
    tags: ['Astro', 'TypeScript', 'Web Components', 'CSS', 'HTML'],
    image: baselinelabImage,
  },
  {
    title: 'TemariOS',
    description:
      'Aplicación para los alumnos del bootcamp de SocraTech donde centralizo guías, recursos, ejercicios, maquetaciones y quizzes para mejorar el seguimiento práctico del aprendizaje.',
    link: 'https://temariosapp.vercel.app/',
    tags: ['React 19', 'TypeScript', 'Supabase', 'CSS'],
    image: temariosImage,
  },
  {
    title: 'FlipiFriends',
    description:
      'Proyecto infantil para seleccionar series animadas y jugar a buscar parejas de cartas, centrado en lógica de interacción, estado y experiencia de usuario.',
    link: 'https://flipifriends.netlify.app',
    tags: ['React 19', 'JavaScript', 'CSS'],
    image: flipifriendsImage,
  },
];
---

<section id="projects" class="py-10 sm:py-20">
  <Container>
    <h2
      class="text-foreground mb-10 flex items-center gap-x-2 text-balance text-3xl font-black"
    >
      Proyectos
    </h2>
    <div class="grid grid-cols-2 gap-4">
      {
        projects.map(({ title, description, link, tags, image }, index) => (
          <article class="project border-border bg-surface-elevated shadow-sjr col-span-2 flex min-w-0 flex-col gap-y-4 overflow-clip rounded-3xl border transition-[border] duration-100 [corner-shape:squircle] hover:border-4 md:col-span-1 md:first:col-span-2">
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Ver proyecto ${title}`}
            >
              <Image
                src={image}
                alt={title}
                class="w-full"
                width={1920}
                height={1080}
                fetchpriority={index === 0 ? 'high' : 'low'}
                loading={index === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </a>
            <div class="space-y-2 p-5">
              <h3 class="text-primary-strong text-2xl font-extrabold">
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-title-link inline-flex items-center gap-x-2"
                >
                  {title}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="project-title-icon size-5 opacity-0 transition-opacity duration-150"
                    aria-hidden="true"
                  >
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6" />
                    <path d="M11 13l9 -9" />
                    <path d="M15 4h5v5" />
                  </svg>
                </a>
              </h3>
              <p class="text-pretty">{description}</p>
              <ul class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <li>
                    <TechnologyPill>{tag}</TechnologyPill>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .project:hover ~ .project,
  [id='projects']:has(.project:hover) .project:not(:hover) {
    filter: blur(4px) brightness(0.8);
  }

  .project-title-link:hover .project-title-icon,
  .project:focus-within .project-title-icon {
    opacity: 1;
  }
</style>
