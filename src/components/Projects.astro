---
import Container from '@/components/Container.astro';
import IconPill from '@/components/IconPill.astro';
import TechnologyPill from '@/components/TechnologyPill.astro';
import ExternalLinkIcon from '@/assets/icons/ExternalLinkIcon.svg';

const projects = [
  {
    title: 'BaselineLab',
    description:
      'Plataforma en desarrollo con playgrounds y generadores de CSS y HTML, orientada a acelerar pruebas visuales, creación de código y productividad frontend.',
    link: 'https://baselinelab.dev',
    tags: ['Astro', 'TypeScript', 'CSS'],
  },
  {
    title: 'TemariOS',
    description:
      'Aplicación para alumnos de bootcamp donde centralizo guías, recursos, ejercicios, maquetaciones y quizzes para mejorar el seguimiento práctico del aprendizaje.',
    link: 'https://temari-os.vercel.app',
    tags: ['React 19', 'TypeScript', 'Supabase'],
  },
  {
    title: 'FlipyFriends',
    description:
      'Proyecto infantil para seleccionar series animadas y jugar a buscar parejas de cartas, centrado en lógica de interacción, estado y experiencia de usuario.',
    link: 'https://flipifriends.netlify.app',
    tags: ['React 19', 'JavaScript', 'CSS'],
  },
];
---

<section id="projects" class="py-10 sm:py-20">
  <Container>
    <h2
      class="text-foreground mb-10 flex items-center gap-x-2 text-balance text-3xl font-black"
    >
      Proyectos
    </h2>
    <div class="grid gap-4 md:grid-cols-3">
      {
        projects.map(({ title, description, link, tags }) => (
          <article class="border-border bg-surface-elevated flex min-w-0 flex-col gap-y-4 rounded-lg border p-5 shadow-sm shadow-black/5">
            <h3 class="text-primary-strong wrap-break-words text-xl font-extrabold">
              {title}
            </h3>
            <p class="text-muted text-pretty text-sm leading-6">
              {description}
            </p>
            <ul class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <li>
                  <TechnologyPill>{tag}</TechnologyPill>
                </li>
              ))}
            </ul>
            <div class="mt-auto pt-2">
              <IconPill href={link} label={`Abrir proyecto ${title}`}>
                <ExternalLinkIcon class="size-5" aria-hidden="true" />
                Ver proyecto
              </IconPill>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
