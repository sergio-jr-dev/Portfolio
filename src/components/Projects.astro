---
import { Image } from 'astro:assets';
import Container from '@/components/Container.astro';
import TechnologyPill from '@/components/TechnologyPill.astro';
import baselinelabImage from '@/assets/images/projects/baselinelab.webp';
import temariosImage from '@/assets/images/projects/temarios.webp';
import flipifriendsImage from '@/assets/images/projects/flipi-friends.webp';

const projects = [
  {
    title: 'BaselineLab',
    description:
      'Plataforma en desarrollo con playgrounds y generadores de CSS y HTML, orientada a acelerar pruebas visuales, creación de código y productividad frontend.',
    link: 'https://baselinelab.dev',
    tags: ['Astro', 'TypeScript', 'Web Components', 'CSS', 'HTML'],
    image: baselinelabImage,
  },
  {
    title: 'TemariOS',
    description:
      'Aplicación para los alumnos del bootcamp de SocraTech donde centralizo guías, recursos, ejercicios, maquetaciones y quizzes para mejorar el seguimiento práctico del aprendizaje.',
    credentials: {
      title: 'Credenciales para probar la aplicación:',
      user: 'Demo',
      password: '4$1W8mhUgTw2CPQp',
    },
    link: 'https://temariosapp.vercel.app/',
    tags: ['React 19', 'TypeScript', 'Supabase', 'CSS'],
    image: temariosImage,
  },
  {
    title: 'FlipiFriends',
    description:
      'Proyecto infantil para seleccionar series animadas y jugar a buscar parejas de cartas, centrado en lógica de interacción, estado y experiencia de usuario.',
    link: 'https://flipifriends.netlify.app',
    tags: ['React 19', 'JavaScript', 'CSS'],
    image: flipifriendsImage,
  },
];
---

<section id="projects" class="py-10 sm:py-20">
  <Container>
    <h2
      class="text-foreground mb-10 flex items-center gap-x-2 text-balance text-3xl font-black"
    >
      Proyectos
    </h2>
    <div class="grid gap-4 md:grid-cols-2">
      {
        projects.map(
          ({ title, description, credentials, link, tags, image }, index) => (
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              class="border-border bg-surface-elevated shadow-sjr flex min-w-0 flex-col gap-y-4 overflow-clip rounded-3xl border shadow [corner-shape:squircle] first:col-span-2"
            >
              <article>
                <Image
                  src={image}
                  alt={title}
                  class="h-auto w-full"
                  width={1920}
                  height={1080}
                  fetchpriority={index === 0 ? 'high' : 'low'}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                <div class="space-y-2 p-5">
                  <h3 class="text-primary-strong text-2xl font-extrabold">
                    {title}
                  </h3>
                  <p class="text-pretty">{description}</p>
                  {credentials && (
                    <>
                      <p>{credentials.title}</p>
                      <ul class="list-disc ps-8">
                        <li>{credentials.user}</li>
                        <li>{credentials.password}</li>
                      </ul>
                    </>
                  )}
                  <ul class="flex flex-wrap gap-2">
                    {tags.map((tag) => (
                      <li>
                        <TechnologyPill>{tag}</TechnologyPill>
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            </a>
          )
        )
      }
    </div>
  </Container>
</section>
