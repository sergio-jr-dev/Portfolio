---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/Container.astro";
import Experience from "@/components/Experience.astro";
import Projects from "@/components/Projects.astro";
import BriefCaseIcon from "@/icons/BriefCaseIcon.astro";
import ProyectsIcon from "@/icons/ProjectsIcon.astro";
import StartDescription from "@/components/StartDescription.astro";
---

<Layout
  title="Portfolio de Sergio Jiménez. Desarrollador y programador web enfocado en frontend."
  description="Descubre mi portafolio donde encontrarás mis proyectos más destacados y conocerás a fondo mis conocimientos."
>
  <Container id="start">
    <StartDescription />
  </Container>

  <Container id="experience">
    <BriefCaseIcon class="size-7" slot="title-icon" />
    <Experience />
  </Container>

  <Container id="projects">
    <ProyectsIcon class="size-7" slot="title-icon" />
    <Projects />
  </Container>
</Layout>
