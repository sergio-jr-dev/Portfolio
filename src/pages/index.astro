---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/Container.astro";
import Experience from "@/components/Experience.astro";
import Projects from "@/components/Projects.astro";
import StartDescription from "@/components/StartDescription.astro";
import About from "@/components/About.astro";
---

<Layout
  title="Portfolio de Sergio Jiménez. Desarrollador Frontend / Full Stack."
  description="Portfolio de Sergio Jiménez Rubio, desarrollador web con experiencia en frontend, herramientas internas, docencia técnica e IA aplicada al desarrollo."
>
  <Container id="start">
    <StartDescription />
  </Container>

  <Container id="about">
    <About />
  </Container>

  <Container id="experience">
    <Experience />
  </Container>

  <Container id="projects">
    <Projects />
  </Container>
</Layout>
