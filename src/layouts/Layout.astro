---
import { Font } from 'astro:assets';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';

import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html
  lang="es"
  class="scrollbar-thin scrollbar-thumb-primary selection:bg-primary-soft selection:color-primary-strong scroll-smooth"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="#f7faf8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#071412"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <Font cssVariable="--font-onest" />
  </head>

  <body
    class="bg-(image:--bg-main) flex min-h-dvh flex-col bg-cover bg-fixed font-sans antialiased"
  >
    <a
      class="focus:bg-surface focus:text-primary-strong focus-visible:ring-ring sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:shadow-lg focus:outline-none focus-visible:ring-2"
      href="#main-content"
    >
      Saltar al contenido
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
